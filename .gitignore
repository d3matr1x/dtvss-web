# =============================================================================
# DTVSS .gitignore
# =============================================================================
# Protects secrets, build artifacts, local dev files, and OS/IDE noise from
# being committed. Organized by category so additions are easy to slot in.

# -----------------------------------------------------------------------------
# SECRETS — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.json
credentials.json
*.secret
# NVD API keys sometimes end up in ad-hoc files during debugging
nvd_key.txt
api_keys.txt

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.whl
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
virtualenv/
pyvenv.cfg

# Python type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.pylint.d/

# Python testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.tox/
.nox/
nosetests.xml

# Jupyter / IPython (in case anyone ever uses them for calibration work)
.ipynb_checkpoints
*.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# DTVSS-specific runtime / local state
# -----------------------------------------------------------------------------
# Persistent volume contents (never commit production data)
data/
/data/
*.db
*.sqlite
*.sqlite3

# Index backups created by atomic_write_json
static/data/mdm_index.json.bak
static/data/*.bak
static/data/*.tmp
static/data/.*.tmp

# Calibration working files — keep the canonical dataset.csv, skip regenerated
# artifacts the user might produce locally
calibration/dataset.csv.bak
calibration/results.json.bak
calibration/*.tmp

# Logs
*.log
logs/
log/

# Local test outputs
test-results/
test_output/
*.test.tmp

# -----------------------------------------------------------------------------
# OS / Filesystem
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
ehthumbs.db
ehthumbs_vista.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.fseventsd
.TemporaryItems
.VolumeIcon.icns

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Emacs / nano
*.swp
*.swo
*~
.*.swp
.*.swo
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Deployment / local dev
# -----------------------------------------------------------------------------
# Railway CLI local cache
.railway/

# Docker local files (if you ever containerize locally)
docker-compose.override.yml
.dockerignore.local

# Node (in case any frontend tooling is added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# -----------------------------------------------------------------------------
# Security audit artifacts — track the REPORT, not the working files
# -----------------------------------------------------------------------------
# Keep committed: PENTEST_REPORT.md, PENTEST_RAILWAY_ADDENDUM.md, security.py
# Skip: local scan outputs that could reveal live vulnerabilities
pentest_scratch/
scan_results/
burp_projects/
*.nessus
nmap_*.xml
nmap_*.nmap
nmap_*.gnmap

# pip-audit / safety / bandit local reports (commit cleaned summaries only)
pip-audit.json
safety_report.json
bandit-report.json

# -----------------------------------------------------------------------------
# Patent / legal working files
# -----------------------------------------------------------------------------
# Drafts and working copies don't belong in the public repo.
# The filed patent PDF belongs in a separate private IP repo, not here.
patent_drafts/
patent_working/
*_DRAFT.pdf
*_WORKING.pdf
# But DO track the filed version if you've chosen to include it:
!DTVSS_Provisional_Patent_IPA_Filed.pdf

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Backups from sed -i, editor autosaves, etc.
*.bak
*.backup
*.orig
*.rej

# Temporary directories
tmp/
temp/
.tmp/
.cache/

# OS-specific lock files
*.pid
*.lock
