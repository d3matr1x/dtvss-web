# DTVSS Environment Variables
# Copy to .env and fill in values

# NVD API Key (optional but recommended - 50 req/30s vs 5 req/30s)
# Free key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Port (Railway sets this automatically)
PORT=5000

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (bot challenge on /api/lookup, /api/search, /api/score)
# -----------------------------------------------------------------------------
# Sign up: https://dash.cloudflare.com -> Turnstile -> Add site
# Use widget mode "Managed" for invisible-by-default UX.
#
# If both vars are unset, the API falls open (one-time warning logged) so
# local dev works without Cloudflare credentials. DO NOT deploy to prod
# with these unset.
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# -----------------------------------------------------------------------------
# API key bypass (for programmatic / CLI access to /api/*)
# -----------------------------------------------------------------------------
# Comma-separated list of pre-shared keys. Clients send `X-API-Key: <key>`
# to skip the Turnstile challenge. Keys must be high-entropy (>= 32 random
# chars; e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
# Rotation: update this var and redeploy; takes effect on next request.
DTVSS_API_KEYS=
